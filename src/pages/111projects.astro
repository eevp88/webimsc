---
import Layout from "@/layouts/Layout.astro";
import { SITE } from "@/consts/sitio";

const title = ` Proyectos Destacados - ${SITE.name}`;
---

<Layout title={title}>
  <section class="py-16">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <h2
        class="text-3xl font-extrabold text-gray-900 dark:text-gray-200 mb-8 text-center"
      >
        Proyectos Destacados
      </h2>
      <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
        <!-- Proyecto 1 -->
        <div
          class="rounded-lg shadow-lg overflow-hidden bg-white dark:bg-gray-800"
        >
          <img
            src="/images/proyecto1.jpg"
            alt="Proyecto 1"
            class="w-full h-48 object-cover"
          />
          <div class="p-6">
            <h3
              class="text-xl font-semibold mb-2 text-gray-900 dark:text-gray-200"
            >
              Proyecto de Energía Renovable
            </h3>
            <p class="text-gray-700 dark:text-gray-300">
              Implementación de un sistema de energía solar para una planta
              industrial, logrando una reducción del 30% en costos energéticos.
            </p>
          </div>
        </div>

        <!-- Proyecto 2 -->
        <div
          class="rounded-lg shadow-lg overflow-hidden bg-white dark:bg-gray-800"
        >
          <img
            src="/images/proyecto2.jpg"
            alt="Proyecto 2"
            class="w-full h-48 object-cover"
          />
          <div class="p-6">
            <h3
              class="text-xl font-semibold mb-2 text-gray-900 dark:text-gray-200"
            >
              Optimización de Procesos Industriales
            </h3>
            <p class="text-gray-700 dark:text-gray-300">
              Rediseño de la línea de producción para mejorar la eficiencia
              operativa, resultando en un aumento del 20% en la productividad.
            </p>
          </div>
        </div>

        <!-- Proyecto 3 -->
        <div
          class="rounded-lg shadow-lg overflow-hidden bg-white dark:bg-gray-800"
        >
          <img
            src="/images/proyecto3.jpg"
            alt="Proyecto 3"
            class="w-full h-48 object-cover"
          />
          <div class="p-6">
            <h3
              class="text-xl font-semibold mb-2 text-gray-900 dark:text-gray-200"
            >
              Desarrollo de
            </h3>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
